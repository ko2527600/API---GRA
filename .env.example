# Application Configuration
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000
API_VERSION=1.0.0

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/gra_api
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=False

# Security
API_SECRET_KEY=your-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-change-in-production
ALGORITHM=HS256

# CORS Configuration
CORS_ALLOW_CREDENTIALS=True

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
RATE_LIMIT_ENABLED=True

# GRA API Configuration
GRA_API_BASE_URL=https://apitest.e-vatgh.com
GRA_API_TIMEOUT=30
GRA_API_RETRIES=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=

# Async Processing
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_ENABLED=True

# Retry Configuration
MAX_RETRIES=5
RETRY_BACKOFF_BASE=1
RETRY_BACKOFF_MAX=3600

# Caching
CACHE_ENABLED=True
CACHE_TTL_TIN_VALIDATION=86400
CACHE_TTL_HEALTH_CHECK=300

# Webhooks
WEBHOOK_ENABLED=True
WEBHOOK_MAX_RETRIES=5
WEBHOOK_TIMEOUT=30
WEBHOOK_BACKOFF_BASE=1

# Audit Logging
AUDIT_LOG_ENABLED=True
AUDIT_LOG_RETENTION_DAYS=2555
AUDIT_LOG_MASK_SENSITIVE=True

# Data Retention
SUBMISSION_RETENTION_DAYS=2555
WEBHOOK_LOG_RETENTION_DAYS=90

# Submission Processing
SUBMISSION_PROCESSING_TIMEOUT=300
SUBMISSION_POLLING_INTERVAL=5
SUBMISSION_POLLING_MAX_ATTEMPTS=60

# Secrets Management
SECRETS_BACKEND=local
SECRETS_ENCRYPTION_KEY=your-encryption-key-change-in-production
SECRETS_KEY_ROTATION_ENABLED=False
SECRETS_KEY_ROTATION_DAYS=90
SECRETS_AUDIT_ENABLED=True
SECRETS_AUDIT_LOG_RETENTION_DAYS=2555
SECRETS_CREDENTIAL_ROTATION_ENABLED=False
SECRETS_CREDENTIAL_ROTATION_DAYS=180
SECRETS_REVOCATION_ENABLED=True

# HashiCorp Vault Configuration (optional)
VAULT_ADDR=
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_ENGINE_PATH=secret
VAULT_SECRET_PATH=gra-credentials
VAULT_SKIP_VERIFY=False

# AWS Secrets Manager Configuration (optional)
AWS_REGION=
AWS_SECRET_NAME_PREFIX=gra-api
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Azure Key Vault Configuration (optional)
AZURE_VAULT_URL=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
